# SAP Connection Settings for vibing-steampunk
# Copy this file to .env and fill in your credentials

# SAP ADT endpoint URL (e.g., http://sapsc3.ebydos.local:50000)
SAP_URL=http://<SAP_HOST>:<SAP_PORT>

# SAP login credentials
SAP_USER=<YOUR_SAP_USER>
SAP_PASSWORD=<YOUR_SAP_PASSWORD>

# SAP client number (e.g., 100)
SAP_CLIENT=100

# SAP language (EN, DE, etc.)
SAP_LANGUAGE=EN

# SAP mode: adt (default) or rfc
SAP_MODE=adt

# Enable verbose logging (true/false)
SAP_VERBOSE=false

# Transport management
SAP_ENABLE_TRANSPORTS=false
SAP_FEATURE_TRANSPORT=
